{
  "POST /api/auth/signin": {
    "success": {
      "input": {
        "email": "john@example.com",
        "password": "correctpassword"
      },
      "header": {
        "Content-Type": "application/json"
      },
      "output": {
        "status": 200,
        "body": {
          "user": {
            "id": "user_test1",
            "username": "johndoe",
            "email": "john@example.com",
            "fullName": "John Doe",
            "phone": "+1 (555) 123-4567",
            "organization": "Acme Corp"
          },
          "token": "simulated-jwt-token-for-user_test1"
        }
      }
    },
    "invalid_credentials": {
      "input": {
        "email": "john@example.com",
        "password": "wrongpassword"
      },
      "header": {
        "Content-Type": "application/json"
      },
      "output": {
        "status": 401,
        "body": {
          "message": "Invalid email or password."
        }
      }
    }
  },
  "GET /api/events": {
    "default": {
      "input": {},
      "header": {
        "Content-Type": "application/json",
        "Authorization": "Bearer simulated-jwt-token-for-user_test1"
      },
      "output": {
        "status": 200,
        "body": [
          {
            "id": "event_test1",
            "title": "Tech Conference 2026",
            "description": "Annual technology conference",
            "startDate": "2026-01-01",
            "endDate": "2026-12-31",
            "location": "San Francisco, CA",
            "registrationCount": 0
          }
        ]
      }
    }
  },
  "GET /api/registrations/event_test1": {
    "default": {
      "input": {
        "eventId": "event_test1"
      },
      "header": {
        "Content-Type": "application/json",
        "Authorization": "Bearer simulated-jwt-token-for-user_test1"
      },
      "output": {
        "status": 200,
        "body": []
      }
    }
  }
}
